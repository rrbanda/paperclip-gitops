# Secrets - never commit real values
secrets/**/*.yaml
!secrets/external-secrets/*.yaml
*.key
*.pem
*.p12

# Environment files
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor files
.idea/
.vscode/
*.swp
*.swo

# Node (if running scripts locally)
node_modules/

# Temp files
*.tmp
*.bak

# Kustomize output
kustomize-output/
